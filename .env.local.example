# ============================================================
# Temuin - Environment Variables
# Copy this file to `.env.local` and fill in your Supabase values.
# Find these in your Supabase project: Settings → API.
# ============================================================

# Public (exposed to the browser) — safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (NEVER expose to the browser). Required for admin/server tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for OAuth redirects & metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Real AI (Gemini). Without this, the app uses a deterministic mock so the
# flow still works. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: Google OAuth is configured in Supabase Auth → Providers.
# No extra env needed here; just enable Google in the dashboard and add
# the callback URL: <NEXT_PUBLIC_SITE_URL>/auth/callback
